---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { SITE_URL } from '../consts';
---

<BaseLayout
  title="404 — Not Found"
  description="Página não encontrada."
  canonical={`${SITE_URL}/404`}
  lang="pt"
  noindex
>
  <section class="py-24 text-center">
    <p class="text-sm uppercase tracking-widest text-slate-500">404</p>
    <h1 class="mt-2 text-4xl font-bold">Página não encontrada</h1>
    <p class="mt-4 text-slate-600">O conteúdo que você procura pode ter sido movido ou não existe.</p>
    <a href="/pt" class="mt-6 inline-block rounded-lg bg-blue-600 px-5 py-3 font-medium text-white hover:bg-blue-700">
      Voltar ao início
    </a>
  </section>
</BaseLayout>
