---
import PostCard from './PostCard.astro';
import { t } from '../../i18n/ui';
import type { Post } from '../../lib/posts';
import type { Locale, Niche } from '../../consts';

interface Props {
  posts: Post[];
  lang: Locale;
  niche: Niche;
}
const { posts, lang, niche } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="mx-auto my-12 max-w-3xl">
      <h2 class="mb-4 text-xl font-bold">{t(lang, 'post.related')}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {posts.map((p) => (
          <PostCard post={p} lang={lang} niche={niche} />
        ))}
      </div>
    </section>
  )
}
