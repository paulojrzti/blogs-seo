---
import PostCard from './PostCard.astro';
import type { Post } from '../../lib/posts';
import type { Locale, Niche } from '../../consts';
import { categoryLabel } from '../../lib/categories';
import { t } from '../../i18n/ui';

interface Props {
  category: string;
  pillar?: Post;
  posts: Post[];
  lang: Locale;
  niche: Niche;
}
const { category, pillar, posts, lang, niche } = Astro.props;
const cluster = posts.filter((p) => !p.data.pillar).slice(0, 6);
const label = categoryLabel(niche, lang, category);
---

<section class="border-t border-slate-200 py-10">
  <header class="mb-6 flex items-end justify-between">
    <h2 class="text-2xl font-bold">{label}</h2>
    <a href={`/${lang}/${niche}/${category}`} class="text-sm text-blue-600 hover:underline">
      {t(lang, 'cta.seeAll')} →
    </a>
  </header>

  {
    pillar && (
      <div class="mb-6">
        <p class="mb-2 text-xs uppercase tracking-wider text-blue-600">
          {t(lang, 'post.pillarBadge')}
        </p>
        <PostCard post={pillar} lang={lang} niche={niche} />
      </div>
    )
  }

  {
    cluster.length > 0 && (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {cluster.map((p) => (
          <PostCard post={p} lang={lang} niche={niche} />
        ))}
      </div>
    )
  }
</section>
