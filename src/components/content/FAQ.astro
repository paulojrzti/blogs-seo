---
import SchemaFAQ from '../seo/SchemaFAQ.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../consts';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
  lang: Locale;
  title?: string;
}

const { items = [], lang, title } = Astro.props;
const heading = title ?? t(lang, 'faq.title');
---

{
  items.length > 0 && (
    <section class="not-prose my-12 rounded-xl border border-slate-200 bg-slate-50/50 p-6">
      <h2 class="mb-4 text-2xl font-bold">{heading}</h2>
      <div class="divide-y divide-slate-200">
        {items.map((item, i) => (
          <details class="group py-3" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between text-base font-medium text-slate-900">
              <span>{item.question}</span>
              <svg
                class="h-4 w-4 shrink-0 transition-transform group-open:rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="mt-2 text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
      <SchemaFAQ items={items} />
    </section>
  )
}
