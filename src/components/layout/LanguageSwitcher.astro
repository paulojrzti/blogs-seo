---
import { localeTag, type Locale } from '../../consts';

interface Props {
  current: Locale;
  translationUrl?: string;
}

const { current, translationUrl } = Astro.props;

const ptHref = current === 'pt' ? Astro.url.pathname : (translationUrl ?? '/pt');
const enHref = current === 'en' ? Astro.url.pathname : (translationUrl ?? '/en');

const active =
  'bg-white shadow-sm ring-2 ring-blue-600 ring-offset-2 ring-offset-white';
const inactive = 'opacity-[0.82] hover:bg-slate-50 hover:opacity-100';
---

<div
  class="inline-flex items-center gap-0.5 rounded-full border border-slate-200/90 bg-white p-0.5 shadow-sm ring-1 ring-slate-900/5"
  role="group"
  aria-label="Idioma"
>
  <a
    href={ptHref}
    hreflang={localeTag('pt')}
    aria-current={current === 'pt' ? 'page' : undefined}
    title="Português"
    class:list={[
      'inline-flex items-center justify-center rounded-full px-1.5 py-1 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600',
      current === 'pt' ? active : inactive,
    ]}
  >
    <span class="sr-only">Português</span>
    <!-- Brasil -->
    <svg
      class="pointer-events-none h-[1.125rem] w-[1.6rem] overflow-hidden rounded-[3px] shadow-inner ring-1 ring-black/10"
      viewBox="0 0 22 15"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <rect width="22" height="15" fill="#009b3a"></rect>
      <path d="M11 1.35 18.95 7.5 11 13.65 3.05 7.5z" fill="#ffdf00"></path>
      <circle cx="11" cy="7.5" r="3.35" fill="#002776"></circle>
    </svg>
  </a>
  <a
    href={enHref}
    hreflang={localeTag('en')}
    aria-current={current === 'en' ? 'page' : undefined}
    title="English"
    class:list={[
      'inline-flex items-center justify-center rounded-full px-1.5 py-1 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600',
      current === 'en' ? active : inactive,
    ]}
  >
    <span class="sr-only">English</span>
    <!-- Estados Unidos -->
    <svg
      class="pointer-events-none h-[1.125rem] w-[1.6rem] overflow-hidden rounded-[3px] shadow-inner ring-1 ring-black/10"
      viewBox="0 0 22 15"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <rect width="22" height="15" fill="#b22234"></rect>
      <path
        fill="#fff"
        d="M0 1.07h22v1.07H0zm0 2.14h22v1.07H0zm0 2.14h22v1.07H0zm0 2.14h22v1.07H0zm0 2.14h22v1.07H0zm0 2.14h22v1.07H0z"
      ></path>
      <rect width="9.4" height="8.05" fill="#3c3b6e"></rect>
    </svg>
  </a>
</div>
