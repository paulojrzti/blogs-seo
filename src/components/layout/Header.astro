---
import { NICHES, NICHE_LABELS, type Locale } from '../../consts';
import { t } from '../../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Locale;
  translationUrl?: string;
}
const { lang, translationUrl } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href={`/${lang}`} class="text-lg font-bold tracking-tight">YourBrand</a>

    <nav class="hidden gap-6 text-sm font-medium md:flex">
      {
        NICHES.map((n) => (
          <a href={`/${lang}/${n}`} class="text-slate-700 hover:text-blue-600">
            {NICHE_LABELS[n][lang]}
          </a>
        ))
      }
      <a href={`/${lang}/search`} class="text-slate-700 hover:text-blue-600">
        {t(lang, 'nav.search')}
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`/${lang}/search`}
        aria-label={t(lang, 'nav.search')}
        class="rounded p-2 text-slate-600 hover:bg-slate-100 md:hidden"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>
      <LanguageSwitcher current={lang} translationUrl={translationUrl} />
    </div>
  </div>
</header>
