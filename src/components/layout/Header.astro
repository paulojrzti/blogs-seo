---
import { NICHES, NICHE_LABELS, type Locale } from '../../consts';
import SearchIcon from '../icons/SearchIcon.astro';
import { t } from '../../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Locale;
  translationUrl?: string;
}
const { lang, translationUrl } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href={`/${lang}`} class="text-lg font-bold tracking-tight">YourBrand</a>

    <nav class="hidden gap-6 text-sm font-medium md:flex">
      {
        NICHES.map((n) => (
          <a href={`/${lang}/${n}`} class="text-slate-700 hover:text-blue-600">
            {NICHE_LABELS[n][lang]}
          </a>
        ))
      }
      <a
        href={`/${lang}/search`}
        class="group inline-flex items-center gap-2 rounded-lg px-2 py-1.5 text-slate-700 transition hover:bg-slate-100 hover:text-blue-600"
      >
        <SearchIcon class="h-5 w-5 shrink-0 text-slate-500 transition group-hover:text-blue-600" />
        <span>{t(lang, 'nav.search')}</span>
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`/${lang}/search`}
        aria-label={t(lang, 'nav.search')}
        class="rounded-lg p-2 text-slate-600 transition hover:bg-slate-100 hover:text-blue-600 md:hidden"
      >
        <SearchIcon class="h-6 w-6" />
      </a>
      <LanguageSwitcher current={lang} translationUrl={translationUrl} />
    </div>
  </div>
</header>
