---
import { NICHES, NICHE_LABELS, type Locale } from '../../consts';
import SearchIcon from '../icons/SearchIcon.astro';
import { t } from '../../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Locale;
  translationUrl?: string;
}
const { lang, translationUrl } = Astro.props;
---

<header
  class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/95 shadow-[0_1px_0_0_rgb(15_23_42_/_0.04)] backdrop-blur-md supports-[backdrop-filter]:bg-white/80"
>
  <div class="mx-auto flex h-[4.25rem] max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <a
      href={`/${lang}`}
      class="text-lg font-bold tracking-tight text-slate-900 transition hover:text-blue-700"
    >
      YourBrand
    </a>

    <nav class="hidden items-center gap-1 text-sm font-medium md:flex lg:gap-2">
      {
        NICHES.map((n) => (
          <a
            href={`/${lang}/${n}`}
            class="rounded-lg px-3 py-2 text-slate-700 transition hover:bg-slate-100 hover:text-blue-600"
          >
            {NICHE_LABELS[n][lang]}
          </a>
        ))
      }
      <a
        href={`/${lang}/search`}
        class="group inline-flex items-center gap-2 rounded-lg px-3 py-2 text-slate-700 transition hover:bg-slate-100 hover:text-blue-600"
      >
        <SearchIcon class="h-[1.35rem] w-[1.35rem] shrink-0 text-slate-600 transition group-hover:text-blue-600" />
        <span>{t(lang, 'nav.search')}</span>
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`/${lang}/search`}
        aria-label={t(lang, 'nav.search')}
        class="rounded-lg p-2 text-slate-600 transition hover:bg-slate-100 hover:text-blue-600 md:hidden"
      >
        <SearchIcon class="h-6 w-6" />
      </a>
      <LanguageSwitcher current={lang} translationUrl={translationUrl} />
    </div>
  </div>
</header>
