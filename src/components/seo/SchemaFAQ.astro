---
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  items: FAQItem[];
}
const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: it.answer,
    },
  })),
};
---

{items.length > 0 && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
