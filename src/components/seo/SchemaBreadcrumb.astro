---
interface Item {
  name: string;
  url: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((it, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: it.name,
    item: it.url,
  })),
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
